# Backend service port
PORT=8000

# SQLite database file path
# In container, /data is mounted from the typing-data volume, change with caution
DB_PATH=/data/typing.db

# Admin login password — REQUIRED, must be a strong password in production
# Generate one with: openssl rand -base64 24
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# JWT signing secret — REQUIRED, at least 32 characters
# Generate one with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_OUTPUT_OF_openssl_rand_hex_32
